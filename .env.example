# ==================== LLM大模型配置 ====================
# 支持的LLM提供商: openai, deepseek, aliyun, baidu
# 推荐国内用户使用: deepseek (速度快、稳定)
LLM_PROVIDER=deepseek

# DeepSeek配置 (国内推荐)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0.1

# 阿里云百炼配置 (国内推荐)
ALIYUN_API_KEY=your-aliyun-api-key-here
ALIYUN_MODEL_NAME=qwen-turbo
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_TEMPERATURE=0.1

# 百度文心配置 (国内推荐)
BAIDU_API_KEY=your-baidu-api-key-here
BAIDU_SECRET_KEY=your-baidu-secret-key-here
BAIDU_MODEL_NAME=ernie-bot
BAIDU_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1
BAIDU_TEMPERATURE=0.1

# OpenAI配置 (需要VPN)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_NAME=gpt-3.5-turbo-16k
OPENAI_TEMPERATURE=0.1

# ==================== 向量数据库配置 ====================
VECTOR_DB_PROVIDER=chroma
VECTOR_DB_PERSIST_DIRECTORY=./data/vector_db
VECTOR_SEARCH_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ==================== 向量模型配置 (国内镜像加速) ====================
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL_LOCAL_PATH=./data/embedding_model
HF_ENDPOINT=https://hf-mirror.com

# ==================== 网络环境配置 ====================
# 离线模式: true/false (离线模式需要预先下载模型)
OFFLINE_MODE=false
# 请求超时时间(秒) - 深度分析需要更长时间
REQUEST_TIMEOUT=180
# 最大重试次数
MAX_RETRIES=3
# 重试间隔(秒)
RETRY_INTERVAL=2
# 网络检测超时(秒)
DETECTION_TIMEOUT=5

# ==================== 知识库配置 ====================
KNOWLEDGE_BASE_DIRECTORY=./data/sample_solutions
